rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global safety net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Check admin privilege by checking the users collection
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.role is string && (data.role == 'buyer' || data.role == 'seller' || data.role == 'admin') &&
             (!data.keys().contains('storeName') || data.storeName is string) &&
             (!data.keys().contains('storeDescription') || data.storeDescription is string) &&
             (!data.keys().contains('storeAddress') || data.storeAddress is string) &&
             (!data.keys().contains('phone') || data.phone is string);
    }

    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.sellerId is string && data.sellerId.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.price is number && data.price >= 0 &&
             data.stock is int && data.stock >= 0 &&
             data.category is string && data.category.size() <= 100 &&
             data.imageUrl is string && data.imageUrl.size() <= 2048;
    }

    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.buyerId is string && data.buyerId.size() <= 128 &&
             data.sellerId is string && data.sellerId.size() <= 128 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.paymentMethod is string && (data.paymentMethod == 'orange_money' || data.paymentMethod == 'momo' || data.paymentMethod == 'card' || data.paymentMethod == 'cod') &&
             data.paymentStatus is string && (data.paymentStatus == 'pending' || data.paymentStatus == 'paid' || data.paymentStatus == 'failed') &&
             data.status is string && (data.status == 'pending' || data.status == 'processing' || data.status == 'shipped' || data.status == 'delivered' || data.status == 'cancelled') &&
             data.deliveryAddress is string && data.deliveryAddress.size() <= 500;
    }

    function isValidMessage(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.chatId is string && data.chatId.size() <= 256 &&
             data.senderId == request.auth.uid &&
             data.receiverId is string && data.receiverId.size() <= 128 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000;
    }

    function isValidReview(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.productId is string && data.productId.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000;
    }

    function isValidAuditLog(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.action is string && data.action.size() <= 500 &&
             data.userId == request.auth.uid;
    }

    // --- Collection Routes ---

    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isSignedIn() && (userId == request.auth.uid || resource.data.role == 'seller' || isAdmin());
      // Only return explicit matches or allow administrators
      allow list: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (userId == request.auth.uid || isAdmin()) && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    // PRODUCTS COLLECTION
    match /products/{productId} {
      allow read: if true; // Public catalog search and detail view
      allow create: if isSignedIn() && isValidId(productId) && incoming().sellerId == request.auth.uid && isValidProduct(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(productId) && (resource.data.sellerId == request.auth.uid || isAdmin()) && isValidProduct(incoming());
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    // ORDERS COLLECTION
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(orderId) && incoming().buyerId == request.auth.uid && isValidOrder(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(orderId) && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin()) && isValidOrder(incoming());
      allow delete: if isAdmin();
    }

    // MESSAGES COLLECTION
    match /messages/{messageId} {
      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(messageId) && isValidMessage(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (resource.data.senderId == request.auth.uid) && isValidMessage(incoming());
      allow delete: if isAdmin();
    }

    // REVIEWS COLLECTION
    match /reviews/{reviewId} {
      allow read: if true; // Anyone can read reviews for a product
      allow create: if isSignedIn() && isValidId(reviewId) && isValidReview(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidReview(incoming());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // AUDIT LOGS COLLECTION
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
